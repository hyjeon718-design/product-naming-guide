# Microsoft Graph API (SharePoint + Outlook 공통 - 한 번만 설정하면 됩니다!)
# 발급: https://portal.azure.com → 앱 등록
# 가이드: 연동가이드/outlook-email.md
OUTLOOK_CLIENT_ID=
OUTLOOK_CLIENT_SECRET=

# 발신 이메일 및 전사 배포 이메일
OUTLOOK_USER_EMAIL=
DISTRIBUTION_EMAIL=

# SharePoint 사이트 URL
# 예: https://your-company.sharepoint.com/sites/marketing
# IT팀에 문의하거나 Teams 채널 → 파일 탭 → SharePoint에서 열기로 확인
SHAREPOINT_SITE_URL=

# Microsoft Teams Incoming Webhook (Teams 알림용)
# 발급: Teams 채널 → ... → 커넥터 → Incoming Webhook
# 가이드: 연동가이드/microsoft-teams.md
TEAMS_WEBHOOK_URL=
